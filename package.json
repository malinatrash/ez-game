{
  "name": "ezgame",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "docker:build": "docker build -t svo-game .",
    "docker:run": "docker run -d -p 80:80 -p 443:443 --name svo-game svo-game",
    "docker:rebuild": "docker build -t svo-game . && docker stop svo-game 2>/dev/null || true && docker rm svo-game 2>/dev/null || true && docker run -d -p 80:80 -p 443:443 --name svo-game svo-game"
  },
  "dependencies": {
    "@vueuse/motion": "^3.0.3",
    "idb-keyval": "^6.2.6",
    "jszip": "^3.10.1",
    "konva": "^10.3.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.39",
    "vue-konva": "^3.4.0",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vue-tsc": "^3.3.5"
  }
}